# MxTac Docker Swarm — Environment Variables
# ============================================
# Copy to .env.swarm, fill in values, then source before deploying:
#   cp .env.swarm.example .env.swarm
#   source .env.swarm
#   docker stack deploy -c docker-stack.yml --with-registry-auth mxtac
#
# Secrets (create separately — NOT stored in this file):
#   echo "$(openssl rand -hex 32)"  | docker secret create mxtac_secret_key -
#   echo "strong-password-here"     | docker secret create mxtac_postgres_password -
#
# Configs (create separately):
#   docker config create nginx_swarm_conf ./nginx/nginx.swarm.conf

# ── Image Registry ────────────────────────────────────────────────────────────
# Registry prefix for pre-built images.
# Build and push before deploying:
#   docker build -t ${IMAGE_PREFIX}/backend:${VERSION} ./backend
#   docker build -t ${IMAGE_PREFIX}/frontend:${VERSION} ./frontend
#   docker push ${IMAGE_PREFIX}/backend:${VERSION}
#   docker push ${IMAGE_PREFIX}/frontend:${VERSION}
IMAGE_PREFIX=mxtac
VERSION=latest

# ── Domain ────────────────────────────────────────────────────────────────────
# Public hostname for CORS and SSL. Used in nginx SSL cert CN.
DOMAIN=mxtac.example.com
