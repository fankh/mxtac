# MxTac Backend — Environment Variables
# Copy to .env and fill in values before running

# ── App ───────────────────────────────────────────────
APP_NAME=MxTac API
VERSION=2.0.0
DEBUG=false

# ── Auth ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mxtac:mxtac@localhost:5432/mxtac

# ── Redis ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:5173","https://mxtac.example.com"]
