# /etc/mxtac/mxtac.env — MxTac production environment
#
# Copy this file to /etc/mxtac/mxtac.env, fill in the values, and
# restrict permissions:
#   sudo install -Dm 640 -o root -g mxtac mxtac.env.example /etc/mxtac/mxtac.env
#
# The file is loaded by the systemd unit via EnvironmentFile=.
# Lines beginning with '#' are ignored. Blank lines are ignored.
# Inline comments are NOT supported — values are taken verbatim.
#
# DO NOT commit this file with real secrets.

# ── Application ────────────────────────────────────────────────────────────────
DEBUG=false

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate a strong key:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL (default). For SQLite single-node mode set:
#   DATABASE_URL=sqlite+aiosqlite:///./data/mxtac.db
DATABASE_URL=postgresql+asyncpg://mxtac:CHANGE_ME@localhost:5432/mxtac

# ── Valkey / Redis ─────────────────────────────────────────────────────────────
VALKEY_URL=redis://localhost:6379/0

# ── Message queue ──────────────────────────────────────────────────────────────
# "memory"  — single-process, no external broker (default for standalone)
# "redis"   — Valkey Streams, required for multi-instance horizontal scaling
# "kafka"   — Redpanda / Kafka, high-throughput production deployments
QUEUE_BACKEND=memory

# Required only when QUEUE_BACKEND=kafka
#KAFKA_BOOTSTRAP_SERVERS=localhost:9092
#KAFKA_CONSUMER_GROUP=mxtac

# ── OpenSearch ─────────────────────────────────────────────────────────────────
# Leave blank to disable OpenSearch (events stored in PostgreSQL only).
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser clients.
# Set to the URL of the frontend or to '*' to allow all (not recommended).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=300
