# MxTac Backend — Environment Variables
# Copy to .env and fill in values before running

# ── App ───────────────────────────────────────────────
APP_NAME=MxTac API
VERSION=2.0.0
DEBUG=false

# ── Auth ──────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://mxtac:mxtac@localhost:5432/mxtac

# ── Valkey (Redis-compatible, BSD-licensed) ───────────
VALKEY_URL=redis://localhost:6379/0

# ── Queue ─────────────────────────────────────────────
QUEUE_BACKEND=memory
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=mxtac

# ── OpenSearch ────────────────────────────────────────
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_USE_SSL=false

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_PER_MINUTE=300

# ── CORS ──────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","https://mxtac.example.com"]

# ── SMTP (Notification Dispatcher) ────────────────────
# Default SMTP settings used by DB-backed email notification channels.
# Individual channels can override these values in their config_json.
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=mxtac-alerts@localhost
