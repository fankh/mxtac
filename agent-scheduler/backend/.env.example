# Agent Scheduler Backend — environment variables
# Copy to .env and fill in real values. Never commit .env.

# --- Database ---
SCHEDULER_DB_URL=sqlite+aiosqlite:///./data/scheduler.db

# --- Server ---
SCHEDULER_HOST=0.0.0.0
SCHEDULER_PORT=13002

# --- Scheduler tuning ---
SCHEDULER_MAX_CONCURRENT=2
SCHEDULER_SPAWN_DELAY=30
SCHEDULER_TASK_TIMEOUT=1800
SCHEDULER_RETRY_MAX=3
SCHEDULER_RETRY_BACKOFF=60
SCHEDULER_AUTO_START=false

# --- Claude API ---
ANTHROPIC_API_KEY=your-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=16384

# --- MxTac ---
MXTAC_PROJECT_ROOT=/path/to/mitre-attack/mxtac

# --- Authentication ---
# Set a strong random value in production. Leave empty to disable auth.
AUTH_PASSWORD=change-me-use-a-strong-random-password
